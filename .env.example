# CCC 환경 설정 — 이 파일을 .env로 복사하고 값을 수정하세요
# cp .env.example .env

# ── 데이터베이스 ──
DATABASE_URL=postgresql://ccc:ccc@127.0.0.1:5434/ccc

# ── LLM (Ollama) ──
LLM_BASE_URL=http://localhost:11434
LLM_MANAGER_MODEL=gpt-oss:120b
LLM_SUBAGENT_MODEL=qwen3:8b

# ── 인증 ──
JWT_SECRET=ccc-jwt-secret-2026
CCC_API_KEY=ccc-api-key-2026
INSTANCE_ID=ccc-001

# ── VM 내부 IP (학생 인프라 기본값) ──
# 학생이 다른 네트워크를 사용하면 여기서 변경
VM_ATTACKER_IP=10.20.30.201
VM_SECU_IP=10.20.30.1
VM_WEB_IP=10.20.30.80
VM_SIEM_IP=10.20.30.100
VM_MANAGER_IP=10.20.30.200
VM_WINDOWS_IP=10.20.30.50
VM_INTERNAL_SUBNET=10.20.30.0/24

# ── 포트 (기본값, 필요 시 변경) ──
# CCC_API_PORT=9100
# BASTION_API_PORT=8003
# SUBAGENT_PORT=8002
# POSTGRES_PORT=5434
