# =========================================================
# CCC Standalone — 학생 1인용 단일 VM 배포 환경설정
# =========================================================
# 학생이 ccc-standalone.sh 실행 시 이 파일을 .env 로 자동 복사합니다.
# 외부 LLM 서버 주소만 환경에 맞게 바꾸세요.

# ----- 외부 LLM (GPU 서빙 서버) -----
# 학교 GPU 서버에 ollama 가 설치되어 있다고 가정합니다.
LLM_BASE_URL=http://192.168.0.109:11434
LLM_MANAGER_MODEL=gpt-oss:120b
LLM_SUBAGENT_MODEL=gemma3:4b

# ----- SSH 계정 (모든 컨테이너 공통) -----
# Windows → VM:2201~2205 로 ssh 접속할 때 사용할 계정/암호
CCC_SSH_USER=ccc
CCC_SSH_PASS=ccc

# ----- 컨테이너 SSH 호스트 포트 -----
SSH_PORT_SECU=2201
SSH_PORT_WEB=2202
SSH_PORT_SIEM=2203
SSH_PORT_BASTION=2204
SSH_PORT_ATTACKER=2205

# ----- 외부에서 직접 접속할 서비스 포트 -----
PORT_WEB_LANDING=80              # http://VMIP/  랜딩 페이지 (가이드 + 링크 모음)
PORT_WAZUH_DASHBOARD=1443        # https://VMIP:1443
PORT_BASTION_API=8003            # http://VMIP:8003
PORT_JUICESHOP=3000              # http://VMIP:3000
PORT_DVWA=8080                   # http://VMIP:8080
PORT_NEOBANK=3001
PORT_GOVPORTAL=3002
PORT_MEDIFORUM=3003
PORT_ADMINCONSOLE=3004
PORT_AICOMPANION=3005

# ----- Bastion 인증 -----
CCC_API_KEY=ccc-api-key-2026
JWT_SECRET=ccc-jwt-secret-2026
