echo "9008003 (flowbits step2) 카운트: $C3 (예상 2 — 양 NIC)"

# Cleanup
ssh 6v6-ips 'sudo rm -f /etc/suricata/rules/local.rules'
ssh 6v6-ips 'sudo suricatasc -c reload-rules'
