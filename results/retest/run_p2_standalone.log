## 💻 실행 명령

```bash
# 1. manager 의 syscheck 설정
ssh 6v6-siem 'sudo grep -B1 -A15 "<syscheck>" /var/ossec/etc/ossec.conf 2>&1 | head -30'

# 2. agent 측 (web) 의 syscheck 활성
ssh 6v6-web 'sudo grep -B1 -A5 "<syscheck>" /var/ossec/etc/ossec.conf 2>&1 | head -15'

# 3. baseline alerts.json
BEFORE=$(ssh 6v6-siem 'sudo wc -l /var/ossec/logs/alerts/alerts.json | awk "{print \$1}"')
echo "baseline: $BEFORE"

# 4. 파일 변경 트리거 (web /etc/passwd touch)
ssh 6v6-web 'sudo bash -c "touch /etc/passwd"'   # mtime 변경
sleep 15   # syscheck realtime + ship + analysisd

# 5. rule 550 검색
AFTER=$(ssh 6v6-siem 'sudo wc -l /var/ossec/logs/alerts/alerts.json | awk "{print \$1}"')
echo "after: $AFTER  delta: $((AFTER - BEFORE))"
ssh 6v6-siem 'sudo tail -20 /var/ossec/logs/alerts/alerts.json | jq "select(.rule.groups | contains([\"syscheck\"])) | {rule_id:.rule.id, desc:.rule.description, agent:.agent.name}"' 2>&1 | head

# 6. realtime vs scheduled (frequency 차이)
echo
echo "=== syscheck 의 두 모드 ==="
cat <<'EOF'
realtime="yes"  — inotify 즉시 (1-2초 지연)
frequency 3600  — 1시간 마다 전체 스캔 (hash 비교)
EOF
```

