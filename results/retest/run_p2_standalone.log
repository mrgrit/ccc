alert http any any -> any any (msg:\"W08 sqlmap UA\"; http.user_agent; content:\"sqlmap\"; nocase; fast_pattern; classtype:web-application-attack; priority:2; sid:9008001; rev:1;)
alert http any any -> any any (msg:\"W08 step1 FlowbitTest UA\"; http.user_agent; content:\"FlowbitTest\"; flowbits:set,fb_w08; flowbits:noalert; sid:9008002; rev:1;)
alert http any any -> any any (msg:\"W08 step2 admin after step1\"; http.uri; content:\"/admin\"; flowbits:isset,fb_w08; classtype:successful-recon; priority:1; sid:9008003; rev:1;)
EOF"'
ssh 6v6-ips 'sudo suricatasc -c reload-rules'
sleep 2

# 3. R/B/P 5 burst sqlmap
ssh 6v6-attacker 'for i in 1 2 3 4 5; do
  curl -s -o /dev/null -A "sqlmap/1.5" -H "Host: juice.6v6.lab" http://10.20.30.1/
done'
sleep 5

# 4. alert 카운트
C1=$(ssh 6v6-ips 'sudo grep "9008001" /var/log/suricata/eve.json | grep -c "\"event_type\":\"alert\""')
echo "9008001 (sqlmap UA) 카운트: $C1 (예상 10 — 5 burst × 2 NIC)"

# 5. flowbits 다단계 트리거
ssh 6v6-attacker 'curl -s -o /dev/null -A "FlowbitTest/W08" -H "Host: juice.6v6.lab" http://10.20.30.1/'
sleep 1
ssh 6v6-attacker 'curl -s -o /dev/null -A "FlowbitTest/W08" -H "Host: juice.6v6.lab" http://10.20.30.1/admin'
