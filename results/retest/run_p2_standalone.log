done

# 2. SQL JOIN — listening_ports + processes
ssh 6v6-fw 'sudo osqueryi --json "SELECT l.port, l.address, p.name FROM listening_ports l JOIN processes p ON l.pid = p.pid WHERE l.address NOT LIKE \"127.%\" LIMIT 5;"' 2>&1

# 3. R/B/P — 침해 시뮬 (web 호스트)
echo "=== Red — 침해 시뮬 ==="
ssh 6v6-web 'sudo useradd -m -s /bin/bash -u 1099 fakeintruder 2>/dev/null && echo created'
ssh 6v6-web 'sudo bash -c "echo \"ssh-rsa AAAAB3NzaFAKEKEY-W08 evil@w08\" >> /root/.ssh/authorized_keys"'
ssh 6v6-web 'sudo bash -c "echo \"* * * * * root /tmp/w08_x.sh\" > /etc/cron.d/w08_backdoor"'
sleep 2

echo "=== Blue — 5 헌팅 ==="
ssh 6v6-web 'sudo osqueryi --json "SELECT username, uid FROM users WHERE uid = 1099;"' 2>&1
ssh 6v6-web 'sudo osqueryi --json "SELECT key_type, key FROM authorized_keys WHERE key LIKE \"%FAKEKEY-W08%\";"' 2>&1
ssh 6v6-web 'sudo osqueryi --json "SELECT command, path FROM crontab WHERE path LIKE \"%w08_backdoor%\";"' 2>&1
ssh 6v6-web 'sudo osqueryi --json "SELECT path, mtime FROM file WHERE path = \"/etc/cron.d/w08_backdoor\";"' 2>&1
ssh 6v6-web 'sudo osqueryi --json "SELECT pid, cmdline FROM processes WHERE cmdline LIKE \"%w08_x.sh%\";"' 2>&1

echo "=== Cleanup ==="
ssh 6v6-web 'sudo userdel -r fakeintruder 2>/dev/null; sudo sed -i "/FAKEKEY-W08/d" /root/.ssh/authorized_keys; sudo rm -f /etc/cron.d/w08_backdoor'
