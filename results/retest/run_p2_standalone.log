ssh 6v6-ips 'sudo suricatasc -c dump-counters | python3 -c "import json,sys; m=json.load(sys.stdin)[\"message\"]; print(\"drops:\",m.get(\"capture.kernel_drops\",0),\"pkts:\",m.get(\"decoder.pkts\",0))"'

