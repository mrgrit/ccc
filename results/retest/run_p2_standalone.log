PROMPT: ## 🎯 단계 2 (20점) — fw nftables NAT + HAProxy 협업 (W02-W03)

3 table + DNAT + conntrack 양방향 + R/B/P HAProxy 80 충돌 + cleanup. 30 분.

## 💻 실행 명령

```bash
# 1. 3 table 가시화
ssh 6v6-fw 'sudo nft list tables'

# 2. DNAT 8888 → web 80 추가 + 검증 + cleanup
ssh 6v6-fw 'sudo nft add rule ip six_nat prerouting iifname "eth0" tcp dport 8888 counter dnat to 10.20.32.80:80'
ssh 6v6-fw 'sudo nft insert rule inet six_filter input position 0 tcp dport 8888 accept'
sleep 2
ssh 6v6-attacker 'curl -s -o /dev/null -w "응답: %{http_code}\n" -H "Host: juice.6v6.lab" http://10.20.30.1:8888/'
sleep 2
ssh 6v6-fw 'sudo conntrack -L 2>/dev/null | grep "dport=8888" | head -1'
H=$(ssh 6v6-fw 'sudo nft -a list chain ip six_nat prerouting | grep "dport 8888" | grep -oE "handle [0-9]+" | head -1 | awk "{print \$2}"')
[ -n "$H" ] && ssh 6v6-fw "sudo nft delete rule ip six_nat prerouting handle $H"
H2=$(ssh 6v6-fw 'sudo nft -a list chain inet six_filter input | grep "dport 8888" | grep -oE "handle [0-9]+" | head -1 | awk "{print \$2}"')
[ -n "$H2" ] && ssh 6v6-fw "sudo nft delete rule inet six_filter input handle $H2"

# 3. R/B/P — HAProxy + DNAT 80 충돌
echo "=== baseline (HAProxy) ==="
ssh 6v6-fw 'sudo conntrack -F 2>/dev/null'
sleep 1
ssh 6v6-attacker 'curl -s -o /dev/null -w "%{http_code}\n" -H "Host: juice.6v6.lab" http://10.20.30.1/'
sleep 1
ssh 6v6-fw 'sudo conntrack -L 2>/dev/null | grep "10.20.30.202" | grep "dport=80" | head -1'

echo "=== DNAT 활성 ==="
ssh 6v6-fw 'sudo nft insert rule ip six_nat prerouting position 0 iifname "eth0" tcp dport 80 counter dnat to 10.20.32.80:80'
ssh 6v6-fw 'sudo conntrack -F 2>/dev/null'
sleep 1
ssh 6v6-attacker 'curl -s -o /dev/null -w "%{http_code}\n" -H "Host: juice.6v6.lab" http://10.20.30.1/'
sleep 1
ssh 6v6-fw 'sudo conntrack -L 2>/dev/null | grep "10.20.30.202" | grep "dport=80" | head -1'

# Cleanup
H=$(ssh 6v6-fw 'sudo nft -a list chain ip six_nat prerouting | grep "dport 80 " | grep -oE "handle [0-9]+" | head -1 | awk "{print \$2}"')
[ -n "$H" ] && ssh 6v6-fw "sudo nft delete rule ip six_nat prerouting handle $H"
```

