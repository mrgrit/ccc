## 💻 실행 명령

```bash
# 1. 3 컨테이너 활성
ssh 6v6-bastion 'docker ps --format "{{.Names}}\t{{.Status}}" | grep -E "siem|wazuh-indexer|wazuh-dashboard"'

# 2. dashboard listen port (컨테이너 내부)
ssh 6v6-wazuh-dashboard 'sudo ss -tlnp 2>&1 | grep 5601 | head' 2>/dev/null || echo "ss 미설치 — netstat 대체"

# 3. HAProxy 의 dashboard backend
ssh 6v6-fw 'sudo grep -A2 "backend dashboard" /etc/haproxy/haproxy.cfg'

# 4. 외부 접근 (학생 PC 가 siem.6v6.lab 로)
curl -k -o /dev/null -s -w "HTTPS: %{http_code}\n" -H "Host: siem.6v6.lab" "https://10.20.30.1/"
curl -k -L -o /dev/null -s -w "redirect: %{http_code}\n" -H "Host: siem.6v6.lab" "https://10.20.30.1/login"

# 5. indexer 활성 (manager 측에서 internal)
ssh 6v6-siem 'curl -k -u admin:admin https://10.20.32.110:9200/_cluster/health 2>&1 | head -3'

# 6. filebeat 상태
