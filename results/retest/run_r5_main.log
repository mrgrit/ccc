```yaml
# /etc/falco/rules.d/psa_restricted.yaml
- rule: PSA Restricted Mount
  desc: Detect creation of mounts with the "restricted" option (e.g., /etc/fstab entries)
  condition: kevt.type = mount and kevt.args contains "restricted"
  output: "Restricted mount detected (mount=%kevt.args) on host %host"
  priority: INFO
  tags: [psa, mount, restricted]
```

