RICATA_LOG="/var/log/suricata/eve.json"
TMP_DIR="/tmp/ir_workflow_$(date +%s)"
MAIL_TO="sec-team@example.com"
MAIL_SUBJ="[IR] 자동 IR 워크플로우 실행 결과"
NFTA_TABLE="filter"
NFTA_CHAIN="INPUT"

# ---------- 함수 ----------
log() { echo -e "[$(date +%H:%M:%S)] $*"; }

# 1️⃣ 탐지 : Wazuh + Suricata 에서 최근 5분간 경고를 추출
detect() {
    log "▶ 탐지 시작"
    mkdir -p "$TMP_DIR"
    # Wazuh alerts (예: level >= 7)
    jq '[.[] | select(.rule.level >= 7)]' "$ALERT_FILE" > "$TMP_DIR/wazuh_alerts.json"

    # Suricata alerts (예: msg에 "SQLi" 포함)
    jq '[.[] | select(.event_type=="alert" and .alert.signature|test("SQLi"))]' "$SURICATA_LOG" > "$TMP_DIR/suricata_alerts.json"

    # 탐지 결과 요약
    ALERT_COUNT=$(jq '. | length' "$TMP_DIR/wazuh_alerts.json")
    SURICATA_COUNT=$(jq '. | length' "$TMP_DIR/suricata_alerts.json")

