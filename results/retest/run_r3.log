def is_filtered(text):
    data = json.dumps({'model':'gemma3:4b','prompt':text,'stream':False,'options':{'num_predict':40}}).encode()
    req = urllib.request.Request('${OLLAMA_URL:-http://192.168.0.105:11434}/api/generate',data=data,headers={'Content-Type':'application/json'})
