local CANARY_RATE = tonumber(os.getenv("CANARY_RATE") or "10")   -- 10% 기본값

function _M.route()
    -- 1~100 사이의 난수 생성
    local rand = math.random(100)
    if rand <= CANARY_RATE then
        return "canary"
    else
        return "stable"
    end
end

return _M
