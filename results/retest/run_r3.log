이 파일은 Python 표준 라이브러리 `statistics` 를 사용해 인터‑Arrival 간격을 계산하고, 평균 대비 표준편차 비율인 CoV를 반환합니다. 파일이 정상적으로 생성되었으며, 이제 해당 함수를 임포트하여 IAT CoV를 손쉽게 계산할 수 있습니다.
import statistics

def iat_cov(timestamps):
    """Calculate Coefficient of Variation (CoV) of Inter-Arrival Times.
    timestamps: iterable of numeric timestamps (e.g., epoch seconds)
    Returns CoV = stdev(intervals) / mean(intervals) or 0 if insufficient data.
    """
    if len(timestamps) < 2:
        return 0.0
    sorted_ts = sorted(timestamps)
    intervals = [t2 - t1 for t1, t2 in zip(sorted_ts, sorted_ts[1:])]
    if not intervals or sum(intervals) == 0:
        return 0.0
    mean = statistics.mean(intervals)
    stdev = statistics.stdev(intervals) if len(intervals) > 1 else 0.0
    return stdev / mean if mean != 0 else 0.0

