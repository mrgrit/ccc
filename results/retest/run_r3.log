def build_prometheus_metrics(data):
    """Convert aggregated dict to Prometheus text format."""
    lines = []

    # Agent request metrics
    for (user, action), cnt in data["agent_requests"].items():
        lines.append(
            f'agent_requests_total{{user="{user}",action="{action}"}} {cnt}'
        )

    # Suricata metrics
    lines.append(f'suricata_alerts_total {data["suricata"]["total"]}')
   
