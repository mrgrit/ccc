```bash
python3 -c "
import urllib.request, json
tests = [
    ('Empty body', b''),
    ('Invalid JSON', b'{invalid}'),
    ('Missing model', json.dumps({'prompt':'hi'}).encode()),
    ('Unknown model', json.dumps({'model':'nonexistent-model','prompt':'hi','stream':False}).encode()),
    ('Wrong type', json.dumps({'model':123,'prompt':'hi','stream':False}).encode()),
    ('Null prompt', json.dumps({'model':'gemma3:4b','prompt':None,'stream':False}).encode()),
]
print('=== Error Handling Security Test ===')
for name, body in tests:
    try:
        req = urllib.request.Request('${OLLAMA_URL:-http://192.168.0.105:11434}/api/generate', data=body, headers={'Content-Type':'application/json'})
        resp = urllib.request.urlopen(req, timeout=5)
        content = resp.read().decode()[:100]
        print(f'[{resp.status}] {name}: {content}')
    except urllib.error.HTTPError as e:
        body_text = e.read().decode()[:100]
        # Check for info leakage
        leaks = [w for w in ['stack','trace','internal','panic','goroutine','file'] if w in body_text.lower()]
        leak_status = f'INFO LEAK: {leaks}' if leaks else 'OK'
        print(f'[{e.code}] {name}: {body_text[:60]} | {leak_status}')
    except Exception as e:
        print(f'[ERR] {name}: {str(e)[:60]}')
"
```

